#!/usr/bin/env ruby
# frozen_string_literal: true

# Flag rejection — block dangerous flags before Thor processes them
BLOCKED_FLAGS = %w[--write --unsafe --exec --eval --agent --dangerously-skip-permissions].freeze

ARGV.each do |arg|
  if BLOCKED_FLAGS.include?(arg.downcase)
    $stderr.puts "Error: flag '#{arg}' is not allowed. qasa-codeagent runs in read-only mode only."
    exit 1
  end
end

require_relative "../lib/qasa_codeagent"

QasaCodeagent::CLI.start(ARGV)
